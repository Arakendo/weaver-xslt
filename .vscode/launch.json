{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Generated Fixture Test",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "test/codegen/generated-fixture-debugger.test.ts",
        "--reporter=basic"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}